{
	"name": "arquitetura_de_software_todolist",
	"version": "1.0.0",
	"description": "Monorepo com backend em Fastify + TypeScript e frontend em Next.js.",
	"main": "index.js",
	"scripts": {
		"dev:server": "npm run dev --workspace=server",
		"build:server": "npm run build --workspace=server",
		"start:server": "npm run start --workspace=server",
		"lint": "biome check",
		"format": "biome format --write",
		"dev:client": "npm run dev --workspace=client",
		"build:client": "npm run build --workspace=client",
		"start:client": "npm run start --workspace=client",
		"dev": "concurrently -n SERVER,CLIENT -c blue,green \"npm run dev:server\" \"wait-on tcp:3333 && npm run dev:client\"",
		"build": "concurrently -n SERVER,CLIENT -c blue,green \"npm run build:server\" \"npm run build:client\"",
		"start": "concurrently -n SERVER,CLIENT -c blue,green \"npm run start:server\" \"npm run start:client\""
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sara-allima/arquitetura_de_software_todolist.git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "commonjs",
	"bugs": {
		"url": "https://github.com/sara-allima/arquitetura_de_software_todolist/issues"
	},
	"homepage": "https://github.com/sara-allima/arquitetura_de_software_todolist#readme",
	"workspaces": [
		"server",
		"client",
		"packages/types"
	],
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@types/node": "^25.5.0",
		"concurrently": "^9.2.1",
		"typescript": "^5.9.3",
		"wait-on": "^9.0.5"
	}
}
